# Campus Connect — Caddy reverse proxy + SPA host (Story 10.3).
# Serves the Angular SPA and proxies /api to the gateway from ONE origin (same-origin =>
# no CORS, SameSite=Lax cookies are sufficient). Auto-HTTPS via Let's Encrypt once {$DOMAIN}
# resolves to this VM and ports 80/443 are reachable. HTTP->HTTPS redirect is automatic.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# API → gateway. `handle /api/*` keeps the /api prefix intact (the gateway routes on
	# /api/student/**, /api/recruiter/**, /api/admin/**, /api/platform/**) — do NOT strip it.
	handle /api/* {
		reverse_proxy api-gateway:8080
	}

	# Everything else is the Angular SPA. try_files falls back to index.html so client-side
	# routes (e.g. /student/drives) survive a refresh / deep link.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	header {
		# No `preload` — it's near-irreversible and would affect the shared duckdns.org parent.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
