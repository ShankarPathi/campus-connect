# Campus Connect — AWS lightweight deploy config. Copy to `.env` and fill REAL values.
#   cp .env.aws.example .env
# `.env` is git-ignored — never commit real secrets.

# Your MongoDB Atlas connection string, with the database name `campusconnect` in the path.
# (Get it from Atlas → Connect → Drivers; URL-encode any special chars in the password.)
SPRING_MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/campusconnect?retryWrites=true&w=majority&appName=Campus-Connect

# JWT signing secret — MUST be >= 32 bytes and NOT the dev default. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-32+-byte-random-secret

# The lowercase GHCR owner the CI pushed the images under.
GHCR_OWNER=shankarpathi

# ── HTTPS (optional — only if you added Caddy for a domain) ──
# Your free DuckDNS subdomain (must point at this box's public IP) + any email for Let's Encrypt.
DOMAIN=campusconnect.duckdns.org
ACME_EMAIL=you@example.com

# The public https base used to build the email-verification link. Defaults to the DuckDNS domain in
# docker-compose.aws.yml, so you usually don't need to set this.
#PUBLIC_BASE_URL=https://shankar-campusconnect.duckdns.org

# ── Email ──
# Default: registration emails go to the on-box Mailpit, viewable at http://<box-ip>:8025 (no real
# delivery — you click the link there). To deliver to REAL inboxes, sign up free at brevo.com and set:
#MAIL_HOST=smtp-relay.brevo.com
#MAIL_PORT=587
#MAIL_USERNAME=your-brevo-login@example.com
#MAIL_PASSWORD=your-brevo-smtp-key
#MAIL_SMTP_AUTH=true
#MAIL_SMTP_STARTTLS=true
