# Campus Connect — Caddy for the AWS box. Sits in front of the existing nginx `frontend`
# and adds automatic free HTTPS (Let's Encrypt) for {$DOMAIN}. nginx still serves the SPA
# and proxies /api → gateway; Caddy just terminates TLS and forwards everything to it.
# Auto-HTTPS kicks in once {$DOMAIN} resolves to this box and ports 80+443 are reachable.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd
	reverse_proxy frontend:80
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
