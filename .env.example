# Campus Connect — production secrets/config (Story 10.1 + 10.3).
# Copy to `.env` and fill in REAL values. `.env` is git-ignored — never commit real secrets.
#   cp .env.example .env

# ── Deploy (Story 10.3) ──
# Your DuckDNS subdomain (must resolve to this VM's public IP) and the Let's Encrypt contact email.
DOMAIN=campusconnect.duckdns.org
ACME_EMAIL=you@example.com
# ghcr owner the CI pushed the service images under (lowercase), e.g. shankarpathi.
GHCR_OWNER=shankarpathi

# ── Monitoring (Story 10.4) ──
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# ── JWT signing (HS256) ──
# MUST be >= 32 bytes and DIFFERENT from the dev default. Generate, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-32+-byte-random-secret

# ── MinIO (object storage: resumes, offer PDFs) ──
MINIO_ROOT_USER=campusconnect
MINIO_ROOT_PASSWORD=change-me-strong-password

# ── SMTP (email: verification, notifications) ──
# Production = Brevo SMTP (smtp-relay.brevo.com:587). Dev = Mailpit (localhost:1025, no auth).
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login
MAIL_PASSWORD=your-brevo-smtp-key

# ── Emailed verification link base URLs (optional) ──
# Repointed at the public SPA route in Story 10.3 (once the domain exists), e.g.
#   STUDENT_VERIFY_BASE_URL=https://campusconnect.duckdns.org/verify-email?portal=student
#   RECRUITER_VERIFY_BASE_URL=https://campusconnect.duckdns.org/verify-email?portal=recruiter
# STUDENT_VERIFY_BASE_URL=
# RECRUITER_VERIFY_BASE_URL=
